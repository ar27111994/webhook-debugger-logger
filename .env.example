# Webhook Debugger & Logger environment example
#
# This project auto-loads a local .env file from the current working directory.
# Existing environment variables still win, so shell, CI, and container-injected
# values override anything defined here.
# Jest test runs intentionally skip .env auto-loading to keep tests deterministic.
#
# Runtime defaults from the project:
# - Local code fallback uses ./storage when APIFY_LOCAL_STORAGE_DIR is unset.
# - Docker images set NODE_ENV=production, ACTOR_WEB_SERVER_PORT=8080,
#   and APIFY_LOCAL_STORAGE_DIR=/app/storage.
# - The Apify actor metadata sets ACTOR_WEB_SERVER_PORT=8080 and PRETTY_LOGS=true.

# -----------------------------------------------------------------------------
# Core runtime configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
ACTOR_WEB_SERVER_PORT=8080
LOG_LEVEL=info
APIFY_LOCAL_STORAGE_DIR=./storage

# Optional runtime toggles
# PRETTY_LOGS=true
# DISABLE_HOT_RELOAD=true
# INPUT='{"urlCount":3,"retentionHours":24,"maxPayloadSize":10485760}'

# Optional path and metadata overrides
# APIFY_ACTOR_DIR=.actor
# APIFY_HOMEPAGE_URL=https://apify.com/ar27111994/webhook-debugger-logger
# DUCKDB_STORAGE_DIR=./storage
# DUCKDB_FILENAME=logs.duckdb
# DUCKDB_MEMORY_LIMIT=512MB
# DUCKDB_VACUUM_ENABLED=false

# Auto-managed by npm in package scripts. Usually do not set manually.
# npm_package_version=3.1.3

# -----------------------------------------------------------------------------
# demo_cli.js only
# -----------------------------------------------------------------------------
# APIFY_ACTOR_URL=http://localhost:8080
# AUTH_KEY=

# -----------------------------------------------------------------------------
# Advanced app tuning overrides
# -----------------------------------------------------------------------------
# DEFAULT_ID_LENGTH=21
# MAX_SSE_CLIENTS=100
# EVENT_MAX_LISTENERS=20
# JSON_INDENT=2
# BACKGROUND_TASK_TIMEOUT_PROD_MS=10000
# ALERT_TIMEOUT_MS=5000
# BACKGROUND_TASK_TIMEOUT_TEST_MS=100
# SCRIPT_EXECUTION_TIMEOUT_MS=1000
# CLEANUP_INTERVAL_MS=600000
# INPUT_POLL_INTERVAL_PROD_MS=5000
# INPUT_POLL_INTERVAL_TEST_MS=100
# SHUTDOWN_TIMEOUT_MS=30000
# SHUTDOWN_RETRY_MAX_ATTEMPTS=3
# SHUTDOWN_RETRY_DELAY_MS=100
# SSE_HEARTBEAT_INTERVAL_MS=30000
# STARTUP_TEST_EXIT_DELAY_MS=5000

# Defaults derived from .actor/input_schema.json
# DEFAULT_URL_COUNT=3
# DEFAULT_RETENTION_HOURS=24
# DEFAULT_REPLAY_RETRIES=3
# MAX_REPLAY_RETRIES=10
# DEFAULT_REPLAY_TIMEOUT_MS=10000
# DEFAULT_RATE_LIMIT_PER_MINUTE=60
# DEFAULT_RATE_LIMIT_MAX_ENTRIES=1000
# DEFAULT_RATE_LIMIT_WINDOW_MS=60000
# DEFAULT_WEBHOOK_RATE_LIMIT_PER_MINUTE=10000
# DEFAULT_WEBHOOK_RATE_LIMIT_MAX_ENTRIES=10000
# DEFAULT_PAYLOAD_LIMIT=10485760
# DEFAULT_FIXED_MEMORY_MBYTES=2048
# DEFAULT_FORWARD_RETRIES=3
# DEFAULT_RESPONSE_CODE=200
# HOT_RELOAD_DEBOUNCE_MS=100

# Safety bounds derived from .actor/input_schema.json
# MAX_SAFE_URL_COUNT=50
# MAX_SAFE_RETENTION_HOURS=168
# MAX_SAFE_RATE_LIMIT_PER_MINUTE=1000
# MAX_SAFE_REPLAY_RETRIES=10
# MAX_SAFE_REPLAY_TIMEOUT_MS=60000
# MAX_SAFE_RESPONSE_DELAY_MS=10000
# MAX_SAFE_FORWARD_RETRIES=10
# MAX_SAFE_FIXED_MEMORY_MBYTES=32768
# MAX_ALLOWED_PAYLOAD_SIZE=104857600
# MIN_REPLAY_TIMEOUT_MS=1000
# MIN_FIXED_MEMORY_MBYTES=256

# Request forwarding and replay internals
# MAX_BULK_CREATE=1000
# RETENTION_LOG_SUPPRESSION_MS=300000
# FORWARD_TIMEOUT_MS=10000
# RETRY_BASE_DELAY_MS=1000
# RETRY_BACKOFF_BASE=2
# CONNECTION_POOL_MAX_SOCKETS=50
# CONNECTION_POOL_MAX_FREE_SOCKETS=10
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
# BASE_ERROR_MSG_LENGTH=100
# CIRCUIT_BREAKER_MAX_SIZE=10000
# CIRCUIT_BREAKER_CLEANUP_INTERVAL_MS=60000

# Signature verification tuning
# SIGNATURE_TOLERANCE_SECONDS=300

# -----------------------------------------------------------------------------
# Database, storage, and pagination tuning
# -----------------------------------------------------------------------------
# DUCKDB_THREADS=4
# DUCKDB_VACUUM_INTERVAL_MS=86400000
# DUCKDB_POOL_SIZE=5
# SYNC_MAX_CONCURRENT=5
# Local default is 5. Apify platform fallback is 1 when this override is unset.
# SYNC_MIN_TIME_MS=500
# SYNC_BATCH_SIZE=1000
# DEFAULT_PAGE_LIMIT=100
# MAX_PAGE_LIMIT=10000
# DEFAULT_PAGE_OFFSET=0
# KVS_OFFLOAD_THRESHOLD=5242880
# MAX_DATASET_ITEM_BYTES=9437184

# Network and SSRF validation tuning
# DNS_RESOLUTION_TIMEOUT_MS=5000
# IDLE_SOCKET_TIMEOUT_MS=30000